---
import { SITE } from '../consts';
---

<section class="hero">
  <div id="particles" class="hero-particles" aria-hidden="true"></div>
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="container hero-inner">
    <img
      src="/assets/pics/headshot.jpeg"
      alt="Portrait of Elliot Chen"
      class="hero-avatar"
      width="160"
      height="160"
      loading="eager"
    />
    <h1 class="hero-name">{SITE.name}</h1>
    <p class="hero-tagline">{SITE.tagline}</p>

    <div class="hero-actions">
      <a href={SITE.github} target="_blank" rel="noopener" class="btn">GitHub</a>
      <a href={SITE.linkedin} target="_blank" rel="noopener" class="btn">LinkedIn</a>
      <a href={`mailto:${SITE.email}`} class="btn">Email</a>
      <a href={SITE.cv} target="_blank" rel="noopener" class="btn">CV</a>
      <a href="/projects/" class="btn">Projects</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero-particles {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 80vw;
    height: 80vw;
    max-width: 900px;
    max-height: 900px;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.1) 0%, rgba(34, 211, 238, 0) 60%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-block: clamp(4rem, 12vh, 8rem);
  }

  .hero-avatar {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border);
    box-shadow: 0 0 0 6px rgba(34, 211, 238, 0.06);
  }

  .hero-name {
    margin-top: 1.5rem;
    font-size: clamp(2.5rem, 7vw, 4rem);
  }

  .hero-tagline {
    margin-top: 0.9rem;
    max-width: 540px;
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  .hero-actions {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }
</style>

<script>
  import { tsParticles } from '@tsparticles/engine';
  import { loadSlim } from '@tsparticles/slim';

  async function initParticles() {
    const container = document.getElementById('particles');
    if (!container) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    await loadSlim(tsParticles);
    await tsParticles.load({
      id: 'particles',
      options: {
        fpsLimit: 60,
        fullScreen: { enable: false },
        background: { color: 'transparent' },
        particles: {
          number: { value: 45, density: { enable: true } },
          color: { value: '#22d3ee' },
          links: {
            enable: true,
            color: '#22d3ee',
            distance: 150,
            opacity: 0.18,
            width: 1,
          },
          move: {
            enable: !reduceMotion,
            speed: 0.5,
            outModes: { default: 'out' },
          },
          opacity: { value: 0.35 },
          size: { value: { min: 1, max: 2.5 } },
        },
        interactivity: {
          events: {
            onHover: { enable: !reduceMotion, mode: 'grab' },
            resize: { enable: true },
          },
          modes: {
            grab: { distance: 160, links: { opacity: 0.4 } },
          },
        },
        detectRetina: true,
      },
    });
  }

  initParticles();
</script>
